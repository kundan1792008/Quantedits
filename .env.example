# =============================================================================
# Quantedits – Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Core application + database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/quantedits
QUANTMAIL_JWT_SECRET=replace-with-a-long-random-secret
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Object Storage (AWS S3 / Cloudflare R2)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Cloudflare R2 (alternative to S3)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=your-r2-bucket-name

# -----------------------------------------------------------------------------
# AI Video Generation (Replicate)
# -----------------------------------------------------------------------------
REPLICATE_API_TOKEN=your-replicate-api-token

# -----------------------------------------------------------------------------
# Internal services
# -----------------------------------------------------------------------------
QUANTTUBE_API_URL=https://api.quanttube.io/v1
RENDER_OUTPUT_BASE_URL=https://renders.quantedits.io

# -----------------------------------------------------------------------------
# FFmpeg / Cloud Render Server
# -----------------------------------------------------------------------------
FFMPEG_SERVER_URL=https://your-ffmpeg-server-url

# -----------------------------------------------------------------------------
# Vercel Deployment (used in GitHub Actions secrets – do not set locally)
# -----------------------------------------------------------------------------
# VERCEL_TOKEN=your-vercel-token
# VERCEL_ORG_ID=your-vercel-org-id
# VERCEL_PROJECT_ID=your-vercel-project-id

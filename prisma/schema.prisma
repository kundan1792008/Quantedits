// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users ──────────────────────────────────────────────────────────────────
// Populated from the Quantmail JWT on first login (biometric SSO).
model User {
  id          String       @id @default(cuid())
  quantmailId String       @unique
  email       String       @unique
  displayName String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  projects    Project[]
  assets      Asset[]
}

// ── Projects ───────────────────────────────────────────────────────────────
model Project {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      ProjectStatus @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  timelines   Timeline[]
  renderJobs  RenderJob[]
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  RENDERED
  PUBLISHED
}

// ── Timelines ──────────────────────────────────────────────────────────────
// Stores a structured JSON timeline produced by the Prompt-to-Timeline API.
model Timeline {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prompt      String
  /// Structured JSON compatible with video-editor timeline formats.
  data        Json
  version     Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Assets ─────────────────────────────────────────────────────────────────
// Stores video clips, audio tracks, memes, etc.
// Includes assets synced from Quanttube.
model Asset {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         AssetType
  title        String
  url          String
  thumbnailUrl String?
  durationSec  Float?
  sizeBytes    BigInt?
  metadata     Json?
  source       AssetSource @default(UPLOAD)
  /// Quanttube asset identifier for synced assets.
  quanttubeId  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([userId, quanttubeId])
}

enum AssetType {
  VIDEO
  AUDIO
  IMAGE
  MEME
  BROLL
}

enum AssetSource {
  UPLOAD
  QUANTTUBE_SYNC
}

// ── RenderJobs ─────────────────────────────────────────────────────────────
model RenderJob {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      RenderJobStatus @default(QUEUED)
  progress    Int             @default(0)
  outputUrl   String?
  errorMsg    String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum RenderJobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}
